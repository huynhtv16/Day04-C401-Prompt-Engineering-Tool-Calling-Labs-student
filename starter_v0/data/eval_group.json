{
  "dataset_id": "day04_v2_research_group",
  "dataset_role": "group",
  "description": "Case do NHÓM tự viết thêm để cover thêm trường hợp. Mỗi case cần: id, phase='B', query HOẶC turns, failure_type (thuộc allowed_failure_types), và expect (tool_calls[...] hoặc no_tool=true). Nên kèm metadata.what_it_tests.",
  "allowed_failure_types": [
    "wrong_tool",
    "wrong_arg_value",
    "wrong_boundary",
    "unnecessary_tool",
    "out_of_scope",
    "missing_info"
  ],
  "cases": [
    {
      "id": "G01_direct_timeline_musk",
      "phase": "B",
      "query": "Tóm tắt 3 tweet mới nhất của Elon Musk.",
      "failure_type": "wrong_arg_value",
      "expect": {
        "tool_calls": [
          {
            "name": "timeline",
            "args": {
              "screenname": "elonmusk",
              "limit": 3
            }
          }
        ]
      },
      "metadata": {
        "skill": "timeline_direct_handle",
        "difficulty": "medium",
        "what_it_tests": "Agent cần gọi timeline với screenname Elon Musk khi user yêu cầu tweet mới nhất."
      }
    },
    {
      "id": "G02_social_search_trending_ai",
      "phase": "B",
      "query": "Cho tôi 5 nội dung trending về AI trên mạng xã hội.",
      "failure_type": "wrong_arg_value",
      "expect": {
        "tool_calls": [
          {
            "name": "social_search",
            "args": {
              "query": "AI",
              "search_type": "Top",
              "limit": 5
            }
          }
        ]
      },
      "metadata": {
        "skill": "social_search_trending",
        "difficulty": "medium",
        "what_it_tests": "Agent phải dùng social_search với query AI và search_type Top."
      }
    },
